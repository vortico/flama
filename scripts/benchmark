#!/bin/bash
set -e

# ─── Benchmark ────────────────────────────────────────────────────────────────
#
# Generates benchmark reports from stored pytest-benchmark JSON results.
#
# Usage:
#   ./scripts/benchmark                  Generate benchmarks/README.md
#   ./scripts/benchmark --compare FILE   Compare FILE against latest stored result (stdout)
#   ./scripts/benchmark --strip FILE     Strip raw timing data from a JSON file

RESULTS_DIR="benchmarks/results"
README_PATH="benchmarks/README.md"
THRESHOLD=5

# Reusable awk function for formatting seconds to human-readable units.
read -r -d '' AWK_FMT <<'AWKFMT' || true
function fmt(s) {
  if (s < 1e-6) return sprintf("%.2f ns", s * 1e9)
  if (s < 1e-3) return sprintf("%.2f us", s * 1e6)
  if (s < 1)    return sprintf("%.2f ms", s * 1e3)
  return sprintf("%.2f s", s)
}
AWKFMT

# ── Helpers ───────────────────────────────────────────────────────────────────

sorted_results() {
  find "$RESULTS_DIR" -name '*.json' 2>/dev/null | sort -V
}

result_date() {
  jq -r '.datetime // empty' "$1" 2>/dev/null | cut -dT -f1
}

# ── Strip ─────────────────────────────────────────────────────────────────────

cmd_strip() {
  local file="$1"
  local tmp
  tmp=$(mktemp)
  jq 'del(.benchmarks[].stats.data)' "$file" > "$tmp" && mv "$tmp" "$file"
}

# ── Latest results table ─────────────────────────────────────────────────────

latest_table() {
  local file="$1"
  echo "| Group | Test | Mean | Std Dev | Rounds |"
  echo "| ----- | ---- | ---: | ------: | -----: |"
  jq -r '.benchmarks | sort_by(.group, .fullname)[] | [.group, .fullname, .stats.mean, .stats.stddev, .stats.rounds] | @tsv' "$file" |
    awk -F'\t' "$AWK_FMT"'{ printf "| %s | %s | %s | %s | %s |\n", $1, $2, fmt($3), fmt($4), $5 }'
}

# ── Comparison table ──────────────────────────────────────────────────────────

comparison_table() {
  local current="$1" previous="$2"
  echo "| Test | Group | Previous | Current | Change | |"
  echo "| ---- | ----- | -------: | ------: | -----: | - |"
  jq -r --slurpfile prev "$previous" '
    ($prev[0].benchmarks | map({(.fullname): .stats.mean}) | add // {}) as $pm |
    .benchmarks | sort_by(.group, .fullname)[] |
    [.fullname, .group, ($pm[.fullname] // -1), .stats.mean] | @tsv
  ' "$current" |
    awk -F'\t' -v threshold="$THRESHOLD" "$AWK_FMT"'
    {
      name=$1; group=$2; prev=$3; curr=$4
      if (prev < 0) {
        printf "| %s | %s | - | %s | new | 🆕 |\n", name, group, fmt(curr)
        new_count++
      } else {
        pct = (prev == 0) ? 0 : (curr - prev) / prev * 100
        sign = (pct > 0) ? "+" : ""
        if (pct < -threshold)     { icon = "🟢"; faster++ }
        else if (pct > threshold) { icon = "🔴"; slower++ }
        else                      { icon = "⚪"; unchanged++ }
        printf "| %s | %s | %s | %s | %s%.1f%% | %s |\n", name, group, fmt(prev), fmt(curr), sign, pct, icon
      }
    }
    END {
      printf "\n"
      printf "**Summary**: **%d** faster, **%d** slower, **%d** unchanged", faster+0, slower+0, unchanged+0
      if (new_count > 0) printf ", **%d** new", new_count
      printf " (threshold: %s%%)\n", threshold
    }'
}

# ── History summary for a pair of versions ────────────────────────────────────

history_summary() {
  local current="$1" previous="$2"
  jq -r --slurpfile prev "$previous" --argjson threshold "$THRESHOLD" '
    ($prev[0].benchmarks | map({(.fullname): .stats.mean}) | add // {}) as $pm |
    [.benchmarks[] |
      ($pm[.fullname] // null) as $prev_mean |
      if $prev_mean == null then "new"
      elif ((.stats.mean - $prev_mean) / $prev_mean * 100) < -$threshold then "faster"
      elif ((.stats.mean - $prev_mean) / $prev_mean * 100) > $threshold then "slower"
      else "unchanged"
      end
    ] | group_by(.) | map({(.[0]): length}) | add // {}
  ' "$current"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_compare() {
  local current_file="$1"
  local latest
  latest=$(sorted_results | tail -1)

  if [[ -z "$latest" ]]; then
    echo "No previous benchmark results to compare against."
    return
  fi

  local latest_version
  latest_version=$(basename "$latest" .json)

  echo "## Performance Comparison (PR vs ${latest_version})"
  echo ""
  comparison_table "$current_file" "$latest"
}

cmd_report() {
  local all_files
  all_files=$(sorted_results)

  if [[ -z "$all_files" ]]; then
    printf "# Benchmark Results\n\nNo benchmark results yet.\n\nRun \`./scripts/performance\` to generate results.\n" > "$README_PATH"
    echo "📊 No results to report."
    return
  fi

  local file_count
  file_count=$(echo "$all_files" | wc -l | tr -d ' ')
  local latest
  latest=$(echo "$all_files" | tail -1)
  local latest_version
  latest_version=$(basename "$latest" .json)
  local latest_date
  latest_date=$(result_date "$latest")

  {
    echo "# Benchmark Results"
    echo ""
    echo "End-to-end performance benchmarks for the Flama framework. Every test builds"
    echo "a full Flama application and measures real HTTP request/response cycles via"
    echo "ASGI transport."
    echo ""
    echo "| Group | What it measures |"
    echo "| ----- | ---------------- |"
    echo "| json | JSON serialization latency at different payload sizes |"
    echo "| routing | Request latency as route table size grows (10/50/200 routes) |"
    echo "| schema | Pydantic input validation and output serialization overhead |"
    echo "| injection | Dependency injection resolution at different chain depths |"
    echo "| middleware | Per-request cost as middleware stack depth increases |"
    echo "| ml | ML model inference latency (sklearn, pytorch, tensorflow) |"
    echo ""
    echo "## Latest: ${latest_version} (${latest_date})"
    echo ""
    latest_table "$latest"
    echo ""

    if [[ "$file_count" -ge 2 ]]; then
      local previous
      previous=$(echo "$all_files" | tail -2 | head -1)
      local prev_version
      prev_version=$(basename "$previous" .json)
      echo "## Comparison: ${latest_version} vs ${prev_version}"
      echo ""
      comparison_table "$latest" "$previous"
      echo ""
    fi

    echo "## Version History"
    echo ""
    echo "| Version | Date | Faster | Slower | Unchanged | New |"
    echo "| ------- | ---- | -----: | -----: | --------: | --: |"

    local prev_file=""
    local files_reversed
    files_reversed=$(echo "$all_files" | sort -rV)

    while IFS= read -r file; do
      local version
      version=$(basename "$file" .json)
      local date
      date=$(result_date "$file")

      if [[ -n "$prev_file" ]]; then
        local summary
        summary=$(history_summary "$prev_file" "$file")
        local faster slower unch new_c
        faster=$(echo "$summary" | jq -r '.faster // "-"')
        slower=$(echo "$summary" | jq -r '.slower // "-"')
        unch=$(echo "$summary" | jq -r '.unchanged // "-"')
        new_c=$(echo "$summary" | jq -r '.new // "-"')
        echo "| ${version} | ${date} | ${faster} | ${slower} | ${unch} | ${new_c} |"
      else
        echo "| ${version} | ${date} | - | - | - | - |"
      fi
      prev_file="$file"
    done <<< "$files_reversed"
  } > "$README_PATH"

  echo "📊 Report generated at ${README_PATH}"
}

# ── Main ──────────────────────────────────────────────────────────────────────

run_benchmark() {
  case "${1:-}" in
  --strip)
    cmd_strip "$2"
    ;;
  --compare)
    cmd_compare "$2"
    ;;
  *)
    cmd_report
    ;;
  esac
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_benchmark "$@"
fi
