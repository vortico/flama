#!/bin/bash
set -e

# ─── Clean ───────────────────────────────────────────────────────────────────

FOLDERS="dist flama.egg-info pip-wheel-metadata site test-results .coverage .pytest_cache .mypy_cache .ruff_cache flama/_templates target"

run_clean() {
  echo "🧹 Cleaning project..."

  for folder in $FOLDERS; do
    if [[ -d "$folder" ]]; then
      rm -rf "$folder"
      echo "  🗑️  Deleted: $folder"
    fi
  done

  find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
  find . -type f \( -name "*.pyc" -o -name "*.pyo" \) -delete 2>/dev/null || true

  echo "✅ Clean complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_clean "$@"
fi
