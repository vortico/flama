#!/bin/bash
set -e

# ─── Typecheck ────────────────────────────────────────────────────────────────

run_typecheck() {
  echo "🔍 Typechecking project..."
  uv run --all-extras --group dev ty check "$@"
  echo "✅ Typecheck complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_typecheck "$@"
fi
