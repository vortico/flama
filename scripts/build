#!/bin/bash
set -e

source "./scripts/clean"

# ─── Build ───────────────────────────────────────────────────────────────────

run_build() {
  if [[ "$1" == "-c" || "$1" == "--clean" ]]; then
    run_clean
  fi

  echo "📦 Building templates..."
  (cd lib/templates && npm i && npm run build)

  echo "📦 Building package..."
  uv run maturin build --release
  echo "✅ Build complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_build "$@"
fi
