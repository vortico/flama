#!/bin/bash
set -e

source "./scripts/_env"
source "./scripts/clean"

# ─── Build ───────────────────────────────────────────────────────────────────

# Abort: --build-templates and --fetch-templates are mutually exclusive.
conflicting_templates_error() {
  echo "❌ Error: --build-templates and --fetch-templates are mutually exclusive." >&2
  exit 1
}

# Build the templates from source using the private @vortico/ui registry.
build_templates() {
  echo "📦 Building templates from source..."
  (cd lib/templates && pnpm_auth install && pnpm build)
}

run_build() {
  local build_core=true
  local templates="skip" # build | fetch | skip
  local clean=false
  for arg in "$@"; do
    case "$arg" in
    -c | --clean) clean=true ;;
    --build-core) build_core=true ;;
    --no-build-core) build_core=false ;;
    --build-templates)
      [[ "$templates" == "fetch" ]] && conflicting_templates_error
      templates="build"
      ;;
    --fetch-templates)
      [[ "$templates" == "build" ]] && conflicting_templates_error
      templates="fetch"
      ;;
    --no-build-templates) templates="skip" ;;
    *)
      echo "❌ Error: unknown option '$arg'." >&2
      exit 1
      ;;
    esac
  done

  if $clean; then
    run_clean
  fi

  case "$templates" in
  build) build_templates ;;
  fetch) ./scripts/fetch_templates ;;
  esac

  if $build_core; then
    echo "📦 Building package..."
    uv run maturin build --release
  fi

  echo "✅ Build complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_build "$@"
fi
