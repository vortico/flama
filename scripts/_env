#!/bin/bash

# ─── Artifact Registry ──────────────────────────────────────────────────────
ARTIFACT_REGISTRY_NPM_HOST="europe-west1-npm.pkg.dev/vortico-core/npm-registry"

# ─── Auth Helpers ────────────────────────────────────────────────────────────

# Print a GCP access token or exit with a helpful message.
require_token() {
  local token
  token=$(gcloud auth print-access-token 2>/dev/null) || true

  if [[ -z "$token" ]]; then
    echo "❌ Error: Could not fetch GCP access token." >&2
    echo "💡 Try running 'gcloud auth login' first." >&2
    exit 1
  fi

  echo "$token"
}

# Run pnpm authenticated against the private @vortico registry. The short-lived token
# (from $ARTIFACT_REGISTRY_TOKEN in CI/WIF, or gcloud locally) is supplied two ways, since
# the environments disagree on which one pnpm honours: the env-config form works locally,
# while the ephemeral userconfig .npmrc is what the GitHub runner's pnpm reads. Both carry
# the same token (env takes precedence where both are read) and neither lands in the repo
# tree. Usage: pnpm_auth <pnpm-args...>
pnpm_auth() {
  local token rc ret=0
  token="${ARTIFACT_REGISTRY_TOKEN:-$(require_token)}"
  rc="$(mktemp)"
  printf '//%s/:_authToken=%s\n' "${ARTIFACT_REGISTRY_NPM_HOST}" "${token}" >"${rc}"
  env "pnpm_config_//${ARTIFACT_REGISTRY_NPM_HOST}/:_authToken=${token}" npm_config_userconfig="${rc}" pnpm "$@" || ret=$?
  rm -f "${rc}"
  return ${ret}
}
