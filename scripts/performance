#!/bin/bash
set -e

# Resolve paths relative to this script so the harness can run from any working directory (the 1.12.4
# reseed runs it from an isolated tree that has no local flama/ source to shadow the pinned install).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/version"

# ─── Performance ──────────────────────────────────────────────────────────────
#
# Measures performance in CI only, under Valgrind/Callgrind, as a deterministic,
# hardware-independent CPU cost: an estimated cycle count (the headline metric) on top of the
# raw instruction count. Each benchmark runs in its own Callgrind process with instrumentation
# disabled at start; the `benchmark` fixture (tests/performance/conftest.py) toggles it on only
# around a fixed-iteration loop, so import/setup is excluded. Not runnable on macOS (Valgrind is
# Linux-only).
#
# Benchmarks run in parallel (one Callgrind process per benchmark, FLAMA_BENCH_JOBS at a time).
# Callgrind counts simulated events on a pinned synthetic CPU (fixed cache geometry + weights,
# PYTHONHASHSEED=0, ASLR off), so the numbers are independent of real-CPU contention: parallelism
# changes wall time only, never the measured counts.
#
# Usage:
#   ./scripts/performance [--output FILE] [--iterations N] [--jobs N] [NODE_ID ...]

PERF_DIR="tests/performance"

# Cycle-estimate weights (tunable): approximate penalties for an L1 miss, a last-level/RAM miss
# and a branch mispredict, added on top of each retired instruction. Pinned so the estimate is
# reproducible regardless of the host CPU. Exported so the parallel workers inherit them.
export W_L1=10
export W_LL=100
export W_BM=10

# Pinned cache geometry (size,assoc,line-size). Without these Callgrind auto-detects the host's
# caches via CPUID, so miss counts — and therefore the cycle estimate — would drift whenever the
# runner hardware changes (exactly what this metric exists to avoid). Fixed values make the
# simulated CPU host-independent: a generic 32 KiB L1 (I/D) and 8 MiB last-level cache.
export CACHE_I1="32768,8,64"
export CACHE_D1="32768,8,64"
export CACHE_LL="8388608,16,64"

# Run a single benchmark under Callgrind and, on success, write one JSON entry to $WORK/entries.
# Invoked by the parallel dispatcher below (one process per benchmark); reads its configuration from
# the exported environment (WORK, PYTHON_BIN, ARCH_PREFIX, PERF_ITER, cache/weight constants).
_run_benchmark_one() {
  local id="$1"
  echo "▶ ${id}"

  local run_dir
  run_dir=$(mktemp -d "$WORK/run.XXXXXX")

  # ARCH_PREFIX is a (possibly empty) "setarch <machine> -R" prefix; word-splitting is intentional
  # and safe (its tokens never contain spaces).
  # shellcheck disable=SC2086
  if ! FLAMA_BENCH_ITER="$PERF_ITER" FLAMA_BENCH_META="$run_dir/meta.tsv" PYTHONHASHSEED=0 \
    $ARCH_PREFIX valgrind --tool=callgrind --instr-atstart=no \
    --cache-sim=yes --branch-sim=yes \
    --I1="$CACHE_I1" --D1="$CACHE_D1" --LL="$CACHE_LL" \
    --callgrind-out-file="$run_dir/cg.out" \
    "$PYTHON_BIN" -m pytest "$id" -p no:xdist -p no:cacheprovider --override-ini="addopts=" -q >/dev/null 2>&1; then
    echo "  ! benchmark failed, skipping: ${id}" >&2
    rm -rf "$run_dir"
    return 0
  fi

  if [[ ! -f "$run_dir/cg.out" || ! -f "$run_dir/meta.tsv" ]]; then
    echo "  ! no measurement recorded, skipping: ${id}" >&2
    rm -rf "$run_dir"
    return 0
  fi

  # Zip the `events:` header with the `totals:` row (same column layout, both prefixed by their
  # label) so event lookup is by name and robust to ordering, then apply the cycle weights. We read
  # `totals:` (the cumulative grand total at end of file) rather than `summary:`: under
  # instrumentation toggling (--instr-atstart=no + callgrind_control) the header `summary:` is
  # written as 0, while `totals:` holds the real counts for the instrumented (measured) region.
  local mean ir
  read -r mean ir < <(awk -v it="$PERF_ITER" -v wl1="$W_L1" -v wll="$W_LL" -v wbm="$W_BM" '
    /^events:/  { for (n = 2; n <= NF; n++) col[$n] = n }
    /^totals:/ {
      Ir = $(col["Ir"])
      l1 = $(col["I1mr"]) + $(col["D1mr"]) + $(col["D1mw"])
      ll = $(col["ILmr"]) + $(col["DLmr"]) + $(col["DLmw"])
      bm = $(col["Bcm"]) + $(col["Bim"])
      printf "%.0f %.0f\n", (Ir + wl1 * l1 + wll * ll + wbm * bm) / it, Ir / it
    }' "$run_dir/cg.out")

  if [[ -z "$mean" || -z "$ir" ]]; then
    echo "  ! could not parse Callgrind output, skipping: ${id}" >&2
    rm -rf "$run_dir"
    return 0
  fi

  local group fullname name
  IFS=$'\t' read -r group fullname name <"$run_dir/meta.tsv"

  jq -nc \
    --arg group "$group" --arg fullname "$fullname" --arg name "$name" \
    --argjson mean "$mean" --argjson ir "$ir" --argjson rounds "$PERF_ITER" \
    '{group: $group, fullname: $fullname, name: $name, stats: {mean: $mean, ir: $ir, stddev: 0, rounds: $rounds}}' \
    >"$(mktemp "$WORK/entries/entry.XXXXXX")"

  rm -rf "$run_dir"
}
export -f _run_benchmark_one

run_performance() {
  local output=""
  # Callgrind is fully deterministic and the fixture already runs warmup iterations, so each measured
  # iteration after warmup yields identical counts (stddev is recorded as 0). A small count is enough;
  # it directly scales the instrumented work, which dominates the heavy benchmarks.
  local iterations="${FLAMA_BENCH_ITER:-3}"
  local jobs="${FLAMA_BENCH_JOBS:-$(nproc 2>/dev/null || echo 1)}"
  local ids=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --output)
      output="$2"
      shift 2
      ;;
    --iterations)
      iterations="$2"
      shift 2
      ;;
    --jobs)
      jobs="$2"
      shift 2
      ;;
    *)
      ids+=("$1")
      shift
      ;;
    esac
  done

  if [[ -z "$output" ]]; then
    local version
    version=$(get_version)
    output="benchmarks/results/${version}.json"
  fi

  if ! command -v valgrind >/dev/null 2>&1; then
    echo "❌ valgrind not found; the performance suite only runs on Linux CI" >&2
    exit 1
  fi

  # Interpreter to run *under* Valgrind. Valgrind must instrument Python directly, so we resolve the
  # interpreter once instead of running `uv run` inside Valgrind (that would profile the uv launcher,
  # not Python). Default: the project venv, resolved via uv with --no-sync so it does NOT re-sync and
  # rebuild the _core in debug, which would clobber a release build. Override with FLAMA_BENCH_PYTHON
  # to measure a different install (e.g. an older flama pinned from PyPI for the baseline).
  local python_bin="${FLAMA_BENCH_PYTHON:-}"
  if [[ -z "$python_bin" ]]; then
    python_bin=$(uv run --no-sync python -c 'import sys; print(sys.executable)' 2>/dev/null || true)
  fi
  if [[ -z "$python_bin" ]]; then
    echo "❌ could not resolve a Python interpreter (set FLAMA_BENCH_PYTHON)" >&2
    exit 1
  fi

  # Disable ASLR for stable memory layout → stable cache-miss counts, but only if it actually works:
  # setarch -R needs the personality syscall, which some sandboxes/containers deny. Probe once and
  # skip silently if denied (the simulation still runs; layout is just slightly less pinned).
  local arch_prefix=""
  if command -v setarch >/dev/null 2>&1 && setarch "$(uname -m)" -R true >/dev/null 2>&1; then
    arch_prefix="setarch $(uname -m) -R"
  fi

  if [[ ${#ids[@]} -eq 0 ]]; then
    mapfile -t ids < <("$python_bin" -m pytest "$PERF_DIR" --collect-only -q --override-ini="addopts=" -p no:xdist -p no:cacheprovider 2>/dev/null | grep '::' || true)
  fi

  if [[ ${#ids[@]} -eq 0 ]]; then
    echo "❌ no benchmarks collected" >&2
    exit 1
  fi

  if [[ "$jobs" -lt 1 ]]; then
    jobs=1
  fi

  local work
  work=$(mktemp -d)
  mkdir -p "$work/entries"

  # Export the per-run configuration the workers read from the environment.
  export WORK="$work"
  export PYTHON_BIN="$python_bin"
  export ARCH_PREFIX="$arch_prefix"
  export PERF_ITER="$iterations"

  echo "🏋️ Running ${#ids[@]} performance benchmarks (Callgrind, ${iterations} iterations, ${jobs} parallel)..."

  printf '%s\n' "${ids[@]}" | xargs -P "$jobs" -I {} bash -c '_run_benchmark_one "$@"' _ {}

  shopt -s nullglob
  local entry_files=("$work"/entries/*)
  shopt -u nullglob

  if [[ ${#entry_files[@]} -eq 0 ]]; then
    rm -rf "$work"
    echo "❌ no benchmark produced a measurement" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$output")"

  jq -s \
    --arg datetime "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg commit "$(git rev-parse HEAD 2>/dev/null || echo '')" \
    --argjson iterations "$iterations" \
    '{datetime: $datetime, commit_info: {id: $commit}, metric: {unit: "callgrind", iterations: $iterations}, benchmarks: (. | sort_by(.group, .fullname))}' \
    "${entry_files[@]}" \
    >"$output"

  rm -rf "$work"
  echo "✅ Performance tests complete. ${#entry_files[@]} benchmarks saved to ${output}"
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_performance "$@"
fi
