#!/bin/bash
set -e

# ─── Install ─────────────────────────────────────────────────────────────────

run_install() {
  echo "📦 Installing Python dependencies..."
  uv sync --all-extras --dev "$@"

  echo "📦 Installing JS dependencies and building templates..."
  (cd lib/templates && npm i && npm run build)

  echo "🦀 Building Rust extension (dev)..."
  uv run maturin develop

  echo "✅ Install complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_install "$@"
fi
