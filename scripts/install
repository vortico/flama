#!/bin/bash
set -e
source "./scripts/build" # provides build_templates (and sources _env, clean)

# ─── Install ─────────────────────────────────────────────────────────────────

run_install() {
  local with_templates=false
  local release=false
  local args=()
  for arg in "$@"; do
    case "$arg" in
    --with-templates) with_templates=true ;;
    --release) release=true ;;
    *) args+=("$arg") ;;
    esac
  done

  echo "📦 Installing Python dependencies..."
  uv sync --all-extras --dev "${args[@]}"

  if $with_templates; then
    build_templates
  else
    ./scripts/fetch_templates
  fi

  if $release; then
    echo "🦀 Building Rust extension (release)..."
    uv run maturin develop --release
  else
    echo "🦀 Building Rust extension (dev)..."
    uv run maturin develop
  fi

  echo "✅ Install complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_install "$@"
fi
