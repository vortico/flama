#!/bin/bash
set -e
source "./scripts/_env"

# ─── Install ─────────────────────────────────────────────────────────────────

run_install() {
  echo "🔐 Fetching Artifact Registry token..."
  local token
  token=$(require_token)

  echo "📦 Installing Python dependencies..."
  uv sync --all-extras --dev "$@"

  echo "📦 Installing JS dependencies and building templates..."
  (cd lib/templates && ARTIFACT_REGISTRY_TOKEN="$token" npm i && npm run build)

  echo "🦀 Building Rust extension (dev)..."
  uv run maturin develop

  echo "✅ Install complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_install "$@"
fi
