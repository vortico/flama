#!/bin/bash
set -e
source "./scripts/build" # provides build_templates (and sources _env, clean)

# ─── Install ─────────────────────────────────────────────────────────────────

run_install() {
  local templates="skip" # build | fetch | skip
  local release=false
  local args=()
  for arg in "$@"; do
    case "$arg" in
    --build-templates)
      [[ "$templates" == "fetch" ]] && conflicting_templates_error
      templates="build"
      ;;
    --fetch-templates)
      [[ "$templates" == "build" ]] && conflicting_templates_error
      templates="fetch"
      ;;
    --no-build-templates) templates="skip" ;;
    --release) release=true ;;
    *) args+=("$arg") ;;
    esac
  done

  echo "📦 Installing Python dependencies..."
  uv sync --all-extras --dev "${args[@]}"

  case "$templates" in
  build) build_templates ;;
  fetch) ./scripts/fetch_templates ;;
  esac

  if $release; then
    echo "🦀 Building Rust extension (release)..."
    uv run maturin develop --release
  else
    echo "🦀 Building Rust extension (dev)..."
    uv run maturin develop
  fi

  echo "✅ Install complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_install "$@"
fi
