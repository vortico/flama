#!/bin/bash
set -e

source "./scripts/clean"
source "./scripts/build"

# ─── Publish ─────────────────────────────────────────────────────────────────

run_publish() {
  if [[ "$1" == "--build" ]]; then
    run_clean
    run_build
  fi

  echo "📤 Publishing package..."
  uv publish
  echo "✅ Publish complete."
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  run_publish "$@"
fi
