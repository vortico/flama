{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@vortico/config/typescript/react",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "./src/",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
